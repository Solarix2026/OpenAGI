# === REQUIRED ===
GROQ_API_KEY=your_groq_key_here
NVIDIA_API_KEY=your_nvidia_key_here

# === OPTIONAL — Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === OPTIONAL — Google ===
GOOGLE_CREDENTIALS_PATH=./google_credentials.json
GOOGLE_TOKEN_PATH=./google_token.json

# === OPTIONAL — Voice ===
TTS_VOICE=en-GB-RyanNeural
WAKE_WORD=jarvis

# === OPTIONAL — User Context ===
USER_CITY=Kuala Lumpur
USER_COUNTRY=Malaysia

# === MODELS ===
GROQ_ROUTER_MODEL=llama-3.1-8b-instant
NVIDIA_MAIN_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_FAST_MODEL=meta/llama-3.1-70b-instruct

# === CONFIG ===
WEBUI_PORT=8765
MAX_HISTORY_TURNS=8
WORKSPACE=./workspace
